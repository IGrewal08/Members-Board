<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/index.css" />
    <link rel="stylesheet" href="/form.css" />
    <title>Log-in</title>
  </head>
  <body>
    <header>
      <a href="/" id="logo"> MEMBERS </a>
      <% if (!locals.currentUser) { %>
      <div id="accountStatus">
        <a href="/login" id="loginButton">Login</a>
        <a href="/signup" id="loginButton">Create An Account</a>
      </div>
      <% } else { %>
      <div id="accountStatus">
        <div>Hello, <%= locals.currentUser.username %>!</div>
        <a href="/logout" id="logoutButton">Logout</a>
      </div>
      <% } %>
    </header>
    <main>
      <form action="/login" method="POST">
        <h1>Login To Your Account</h1>
        <label for="username">
          <input
            type="text"
            id="username"
            name="username"
            placeholder="Username"
            required
          />
        </label>
        <label for="password">
          <input
            type="password"
            id="password"
            name="password"
            placeholder="Password"
            required
          />
        </label>
        <button type="submit" id="loginButton_">Login</button>
      </form>
      <div id="formDesc">
        <h1 id="logoDesc">MEMBERS</h1>
        <h1>
          Don't Have An Account?<br />
          Make An Account For FREE!<br />
          <span id="signupDesc"> Click <a href="/signup">Here</a> </span>
        </h1>
      </div>
    </main>
    <%- include("partials/footer") %>
  </body>
</html>
