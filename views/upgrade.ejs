<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/index.css" />
    <link rel="stylesheet" href="/form.css" />
    <title>Log-in</title>
  </head>
  <body>
    <header>
      <a href="/" id="logo"> MEMBERS </a>
      <% if (!locals.currentUser) { %>
      <div id="accountStatus">
        <a href="/login" id="loginButton">Login</a>
        <a href="/signup" id="loginButton">Create An Account</a>
      </div>
      <% } else { %>
      <div id="accountStatus">
        <div>Hello, <%= locals.currentUser.username %>!</div>
        <a href="/logout" id="logoutButton">Logout</a>
      </div>
      <% } %>
    </header>
    <main>
      <form action="/upgrade" method="POST">
        <h1>Login To Your Account</h1>
        <label for="code">
          <input
            type="text"
            id="code"
            name="code"
            placeholder="code"
            required
          />
        </label>
        <button type="submit" id="loginButton_">Login</button>
      </form>
      <div id="formDesc">
        <h1 id="logoDesc">MEMBERS</h1>
        <h1>
          Upgrade Account Membership!<br />
          Become A Admin to see users!<br />
        </h1>
      </div>
    </main>
    <%- include("partials/footer") %>
  </body>
</html>